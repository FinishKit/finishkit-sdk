{
  "name": "@finishkit/sdk",
  "version": "0.3.0",
  "description": "TypeScript SDK for the FinishKit API. Production readiness scanner for AI-built apps.",
  "homepage": "https://finishkit.app",
  "author": "FinishKit <support@finishkit.app>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FinishKit/finishkit-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/FinishKit/finishkit-sdk/issues"
  },
  "keywords": [
    "finishkit",
    "ai",
    "code-review",
    "static-analysis",
    "github",
    "llm",
    "scan",
    "mcp",
    "production-ready",
    "launch-readiness",
    "ship-ready",
    "finish-plan",
    "production-readiness"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
